<!DOCTYPE html>
<html lang="en">

<head>
    <%- include("partials/header.ejs") %>

</head>

<body>
    <h3>Search for a Character</h3>
    <form action="/search" method="POST">
        <input type="text" name="name" placeholder="Enter character name" required>
        <button type="submit">Search</button>
    </form>

    
        <% if (character && character != null) { %>
            <div class="card text-center">
                <img src="<%= character.image %>" alt="<%= character.name %>" class="image">
        
                <h3>Name: <%= character.name %></h3>
                <p>Status: <%= character.status %></p>
                <p>Species: <%= character.species %></p>
                <p>Type: <%= character.type || "N/A" %></p>
                <p>Gender: <%= character.gender %></p>
        
                <p>Origin: <%= character.origin.name %></p>
                <p>Location: <%= character.location.name %></p>
                <p>Episodes: <%= character.episode.length %></p>
            </div>
        
        <% } else if (character == null || !character.data){ %>
            <p>No character found.</p>
        <% } %>

        <%- include("partials/footer.ejs") %>
</body>

</html>